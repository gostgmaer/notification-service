# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_KEY=your-api-key-here
DEFAULT_TENANT_ID=

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/notification-service

# ─── Redis (shared by BullMQ workers + Cache) ────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# ─── Scaling: BullMQ Workers ─────────────────────────────────────────────────
ENABLE_BULL=false
BULL_CONCURRENCY_SMS=5
BULL_CONCURRENCY_EMAIL=10

# ─── Scaling: Kafka ───────────────────────────────────────────────────────────
ENABLE_KAFKA=false
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=notification-service
KAFKA_CLIENT_ID=notification-service
KAFKA_TOPIC_SMS_SEND=sms.notification.send
KAFKA_TOPIC_SMS_DELIVERED=sms.notification.delivered
KAFKA_TOPIC_SMS_FAILED=sms.notification.failed
KAFKA_TOPIC_EMAIL_SEND=email.notification.send
KAFKA_TOPIC_EMAIL_DELIVERED=email.notification.delivered
KAFKA_TOPIC_EMAIL_FAILED=email.notification.failed

# ─── Scaling: Cache ───────────────────────────────────────────────────────────
ENABLE_CACHE=false

# ─── SMS Providers ───────────────────────────────────────────────────────────
SMS_DEFAULT_PROVIDER=mock
SMS_FALLBACK_PROVIDER=
SMS_RETRY_ATTEMPTS=3
SMS_RETRY_DELAY_MS=5000

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WEBHOOK_SECRET=

MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_FLOW_ID=
MSG91_WEBHOOK_SECRET=

FAST2SMS_API_KEY=
FAST2SMS_SENDER_ID=

TEXTLOCAL_API_KEY=
TEXTLOCAL_SENDER=

VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM=
VONAGE_WEBHOOK_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

GUPSHUP_USERID=
GUPSHUP_PASSWORD=

KALEYRA_API_KEY=
KALEYRA_SID=
KALEYRA_SENDER_ID=

D7_API_TOKEN=

EXOTEL_SID=
EXOTEL_TOKEN=
EXOTEL_FROM=

INFOBIP_API_KEY=
INFOBIP_BASE_URL=

TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=

SINCH_SERVICE_PLAN_ID=
SINCH_API_TOKEN=
SINCH_FROM=

PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM=

MESSAGEBIRD_API_KEY=
MESSAGEBIRD_ORIGINATOR=

BREVO_API_KEY=

BULKSMS_USERNAME=
BULKSMS_PASSWORD=

CLICKATELL_API_KEY=

JIOCX_CUSTOMER_ID=
JIOCX_KEY=

AIRTELIQ_CLIENT_ID=
AIRTELIQ_CLIENT_SECRET=

GUPSHUP_USERID=
GUPSHUP_PASSWORD=

ROUTEMOBILE_USERNAME=
ROUTEMOBILE_PASSWORD=
ROUTEMOBILE_SENDER_ID=
ROUTEMOBILE_ACCOUNT=

VALUEFIRST_USERNAME=
VALUEFIRST_PASSWORD=

SMSCOUNTRY_USERNAME=
SMSCOUNTRY_PASSWORD=
SMSCOUNTRY_SENDER_ID=

2FACTOR_API_KEY=

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_MAX_CONNECTIONS=5
EMAIL_MAX_MESSAGES=100
EMAIL_RATE_DELTA=1000
EMAIL_RATE_LIMIT=5
EMAIL_TLS_REJECT_UNAUTHORIZED=true
EMAIL_TLS_MIN_VERSION=TLSv1.2
EMAIL_DEBUG=false

FALLBACK_EMAIL_HOST=
FALLBACK_EMAIL_SERVICE=
FALLBACK_EMAIL_PORT=587
FALLBACK_EMAIL_SECURE=false
FALLBACK_EMAIL_USER=
FALLBACK_EMAIL_PASS=

# Gmail OAuth2
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_REDIRECT_URI=
OAUTH2_REFRESH_TOKEN=

# ─── Throttle ─────────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
